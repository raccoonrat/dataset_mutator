\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Unified framework overview.} The architecture couples \emph  {architectural reconstruction} (left: SISF, context-construction defenses, hybrid judge ensemble with axiological anchoring, policy synthesis and feedback loop) with \emph  {controlled mutation} (right: meta-cognitive monitor, exemplar-guided mutation with golden dataset and experience memory, round scheduling). Assets and oracles sit at the boundary; reconstruction adapts \emph  {who} enforces safety and \emph  {when}, mutation controls \emph  {what} is exposed. Mandatory human calibration and heterogeneous recovery close the loop on judge bias and defensive degradation.}}{3}{figure.1}\protected@file@percent }
\newlabel{fig:framework}{{1}{3}{\textbf {Unified framework overview.} The architecture couples \emph {architectural reconstruction} (left: SISF, context-construction defenses, hybrid judge ensemble with axiological anchoring, policy synthesis and feedback loop) with \emph {controlled mutation} (right: meta-cognitive monitor, exemplar-guided mutation with golden dataset and experience memory, round scheduling). Assets and oracles sit at the boundary; reconstruction adapts \emph {who} enforces safety and \emph {when}, mutation controls \emph {what} is exposed. Mandatory human calibration and heterogeneous recovery close the loop on judge bias and defensive degradation}{figure.1}{}}
