\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {联合键冲突解决路由。}检索键由表面文本语义嵌入与隐藏状态激活特征共同构成。当激活异常超过路由阈值且与看似良性的表面语义冲突时，词典序覆盖抑制语义分支，强制以激活驱动的安全示例从黄金数据集检索，防止 PBU 式伪装劫持示例选择。}}{7}{figure.4}\protected@file@percent }
