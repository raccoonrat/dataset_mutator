# Copy to `env` (gitignored) and fill in secrets. Then: `cd Decoupled-LLM-Gateway && . ./env`
#
# P0: GATEWAY_UPSTREAM must point to the REAL API for paper-grade JSON. If this is
# http://127.0.0.1:9090, the gateway will return [echo] and run_trackA_full_paper.sh
# preflight will refuse to run.

export GATEWAY_UPSTREAM='https://api.deepseek.com'
export DEEPSEEK_API_KEY='your-key-here'
# export OPENAI_API_KEY='...'
# export GATEWAY_UPSTREAM_API_KEY='...'

export GATEWAY_ASYNC_LOG=0
export OPENAI_MODEL='deepseek-chat'

# Optional: long upstream timeout (ms) for slow completions
# export GATEWAY_UPSTREAM_TIMEOUT_MS=120000
