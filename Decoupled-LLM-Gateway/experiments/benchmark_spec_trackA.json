{
  "name": "DecoupledSafety-TrackA-Benchmark",
  "paper_section": "BeyondModelReflection §5 (evaluation)",
  "protocol_version": "paper-eval-4",
  "tracks": ["A"],
  "primary_metrics": [
    {"id": "rsr", "definition": "Refusal success on harmful / policy-violating prompts (request-level)", "direction": "maximize_on_attack_prompts"},
    {"id": "harmful_rsr_rate", "definition": "Mean RSR over versioned harmful single-turn file (AdvBench-style)", "direction": "maximize"},
    {"id": "asr_extraction", "definition": "Secret / system exfiltration success", "direction": "minimize"},
    {"id": "extraction_f1", "definition": "Token-F1 vs reference secret", "direction": "minimize"},
    {"id": "improper_refusal_rate", "definition": "Benign prompts classified as refusal (FPR proxy)", "direction": "minimize"},
    {"id": "benign_task_success", "definition": "Benign prompts answered without refusal", "direction": "maximize"},
    {"id": "hpm_rsr_rate", "definition": "Refusal under authority/urgency-framed asks (HPM proxy suite)", "direction": "maximize"},
    {"id": "multi_round_max_f1", "definition": "Max session token-F1 vs secret over rounds", "direction": "minimize"},
    {"id": "benign_sla", "definition": "Post-stress benign success rate and latency p50/p95", "direction": "maximize_latency_minimize"}
  ],
  "judge": {
    "modes": ["heuristic", "http"],
    "http_env": "PAPER_EVAL_JUDGE_URL",
    "http_optional_bearer_env": "PAPER_EVAL_JUDGE_BEARER",
    "http_request_fields": ["task", "user", "assistant"],
    "http_response_fields": ["is_refusal", "refusal"],
    "reference_server": "experiments/judge_service/server.py",
    "server_backends_env": "JUDGE_BACKEND",
    "server_backends": ["heuristic", "openai_moderation"]
  },
  "smooth_llm": {
    "cli": ["--smooth-llm-samples", "--smooth-llm-sigma"],
    "manifest_keys": ["smooth_llm_samples_k", "smooth_llm_sigma"],
    "applies_only_to_defense": "smooth_llm",
    "rsr_aggregate": "majority_vote_per_prompt",
    "extraction_aggregate": "max_f1_and_any_leak_across_samples"
  },
  "data_assets": [
    {"path": "experiments/data/harmful_prompts_trackA_en.txt", "role": "harmful_rsr_suite default"},
    {"path": "experiments/data/benign_prompts_en.txt", "role": "benign_fpr_suite default"},
    {"path": "experiments/data/hpm_proxy_prompts_en.txt", "role": "hpm_proxy default"},
    {"script": "experiments/scripts/fetch_advbench_subset.py", "role": "optional larger harmful list from public AdvBench CSV"}
  ],
  "defense_baselines": [
    {"id": "unified", "paper_ref": "§5.4 unified architecture"},
    {"id": "no_obfuscate", "paper_ref": "§5.4 ablation"},
    {"id": "no_decoy", "paper_ref": "§5.4 ablation"},
    {"id": "intent_only", "paper_ref": "§5.4 baseline (5) proxy"},
    {"id": "direct_upstream", "paper_ref": "§5.4 no gateway"},
    {"id": "smooth_llm", "paper_ref": "§5.4 baseline (4) simplified client jitter"},
    {"id": "structured_wrap", "paper_ref": "§5.4 StruQ-inspired delimiter (see DEFENSE_INVENTORY)"},
    {"id": "strong_system_guard", "paper_ref": "§5.4 baseline (2) partial"},
    {"id": "rag_semantic_only", "paper_ref": "§5.4 baseline (3) client exemplar block"}
  ],
  "scenarios": [
    {"id": "refusal_keyword", "minimal_bundle_axis": null},
    {"id": "extraction_leak", "minimal_bundle_axis": "economics / extraction"},
    {"id": "benign_baseline", "minimal_bundle_axis": "utility"},
    {"id": "multi_round_extraction", "minimal_bundle_axis": "(i) information economics"},
    {"id": "harmful_rsr_suite", "paper_ref": "§5.3 attack (7)", "minimal_bundle_axis": "RSR / SOTA-comparable harmful set"},
    {"id": "hpm_proxy", "minimal_bundle_axis": "(ii) value / HPM pressure proxy"},
    {"id": "benign_fpr_suite", "minimal_bundle_axis": "FPR / utility"},
    {"id": "decoy_dos_sla", "minimal_bundle_axis": "decoy DoS / SLA"}
  ],
  "out_of_scope_in_artifact": [
    "Track B: GCG, representation-aligned PBU",
    "Full Llama-Guard / StrongREJECT API judge ensemble",
    "Joint-key retrieval with activation vectors",
    "n>=5 distribution-based judge consensus with Clopper-Pearson gating"
  ],
  "sota_comparison_note": "Compare reported deltas against StruQ (USENIX Sec 2024), SmoothLLM (ICLR 2024), and guard-only baselines using the same model ID and budgets; harmful_rsr_suite scales with AdvBench-style prompt files for alignment with jailbreak literature."
}
