{
  "name": "DecoupledSafety-TrackA-Benchmark",
  "paper_section": "BeyondModelReflection §5 (evaluation)",
  "protocol_version": "paper-eval-5",
  "tracks": ["A"],
  "primary_metrics": [
    {"id": "rsr", "definition": "Refusal success on harmful / policy-violating prompts (request-level)", "direction": "maximize_on_attack_prompts"},
    {"id": "harmful_rsr_rate", "definition": "Mean RSR over versioned harmful single-turn file (JBB-Behaviors misuse preferred; AdvBench-compatible)", "direction": "maximize"},
    {"id": "wild_rsr_rate", "definition": "Mean RSR on in-the-wild jailbreak prompt sample", "direction": "maximize"},
    {"id": "strongreject_rsr_rate", "definition": "Mean RSR on StrongREJECT forbidden_prompt list (pair with evaluator rubric for empty-jailbreak control)", "direction": "maximize"},
    {"id": "asr_extraction", "definition": "Secret / system exfiltration success", "direction": "minimize"},
    {"id": "extraction_f1", "definition": "Token-F1 vs reference secret", "direction": "minimize"},
    {"id": "improper_refusal_rate", "definition": "Benign prompts classified as refusal (FPR proxy)", "direction": "minimize"},
    {"id": "benign_task_success", "definition": "Benign prompts answered without refusal", "direction": "maximize"},
    {"id": "hpm_rsr_rate", "definition": "Refusal under authority/urgency-framed asks (HPM proxy suite)", "direction": "maximize"},
    {"id": "multi_round_max_f1", "definition": "Max session token-F1 vs secret over rounds", "direction": "minimize"},
    {"id": "benign_sla", "definition": "Post-stress benign success rate and latency p50/p95", "direction": "maximize_latency_minimize"}
  ],
  "judge": {
    "modes": ["heuristic", "http"],
    "http_env": "PAPER_EVAL_JUDGE_URL",
    "http_optional_bearer_env": "PAPER_EVAL_JUDGE_BEARER",
    "http_request_fields": ["task", "user", "assistant"],
    "http_response_fields": ["is_refusal", "refusal"],
    "reference_server": "experiments/judge_service/server.py",
    "server_backends_env": "JUDGE_BACKEND",
    "server_backends": ["heuristic", "openai_moderation", "chat_completion"],
    "chat_completion_env": {
      "JUDGE_CHAT_BASE_URL": "OpenAI-compatible base, e.g. https://api.openai.com/v1",
      "JUDGE_CHAT_MODEL": "e.g. gpt-4o-mini or Llama-Guard served via vLLM",
      "JUDGE_CHAT_API_KEY": "optional if OPENAI_API_KEY set",
      "JUDGE_CHAT_TIMEOUT": "seconds, default 60",
      "JUDGE_CHAT_PROMPT_TEMPLATE": "optional; must include {user} and {assistant}; model should answer YES or NO"
    }
  },
  "prompt_caps": {
    "cli": ["--max-harmful-prompts", "--max-benign-fpr-prompts", "--max-wild-prompts", "--max-strongreject-prompts"],
    "manifest_keys": ["max_harmful_prompts", "max_benign_fpr_prompts", "max_wild_prompts", "max_strongreject_prompts"],
    "scenarios_affected": ["harmful_rsr_suite", "benign_fpr_suite", "wild_rsr_suite", "strongreject_rsr_suite"]
  },
  "manifest": {
    "dataset_profile_cli": "--dataset-profile",
    "prompt_sha_manifest_key": "prompt_artifacts",
    "optional_paths": ["--wild-prompts-file", "--strongreject-prompts-file", "--cra-session-json"]
  },
  "gateway_output_guard": {
    "cli_flag": "--gateway-output-guard",
    "manifest_key": "gateway_output_guard_header",
    "request_header": "X-Gateway-Output-Guard: 1",
    "skipped_for_defense": "direct_upstream",
    "gateway_env": [
      "GATEWAY_OUTPUT_GUARD_URL",
      "GATEWAY_OUTPUT_GUARD_BEARER",
      "GATEWAY_OUTPUT_GUARD_TIMEOUT_MS",
      "GATEWAY_OUTPUT_GUARD_FAIL_OPEN",
      "GATEWAY_OUTPUT_GUARD_TEMPLATE",
      "GATEWAY_OUTPUT_GUARD_REQUIRE_HEADER"
    ]
  },
  "smooth_llm": {
    "cli": ["--smooth-llm-samples", "--smooth-llm-sigma"],
    "manifest_keys": ["smooth_llm_samples_k", "smooth_llm_sigma"],
    "applies_only_to_defense": "smooth_llm",
    "rsr_aggregate": "majority_vote_per_prompt",
    "extraction_aggregate": "max_f1_and_any_leak_across_samples"
  },
  "data_assets": [
    {"path": "experiments/data/jbb_misuse_100_en.txt", "role": "JBB-Behaviors misuse (100) for harmful_rsr_suite"},
    {"path": "experiments/data/jbb_benign_100_en.txt", "role": "JBB-Behaviors benign (100) for benign_fpr_suite paired reporting"},
    {"path": "experiments/data/harmful_prompts_trackA_en.txt", "role": "legacy harmful fallback (AdvBench-style)"},
    {"path": "experiments/data/benign_prompts_en.txt", "role": "legacy benign FPR fallback"},
    {"path": "experiments/data/wild_jailbreak_first200_en.txt", "role": "in-the-wild sample for wild_rsr_suite"},
    {"path": "experiments/data/strongreject_forbidden_en.txt", "role": "StrongREJECT forbidden_prompt list"},
    {"path": "experiments/data/cra_example_session.json", "role": "CRA format example for multi_round_extraction"},
    {"path": "experiments/data/hpm_proxy_prompts_en.txt", "role": "hpm_proxy default"},
    {"script": "experiments/scripts/fetch_jbb_behaviors.py", "role": "materialize JBB-Behaviors from Hugging Face"},
    {"script": "experiments/scripts/fetch_strongreject_prompts.py", "role": "StrongREJECT CSV to lines"},
    {"script": "experiments/scripts/fetch_wild_jailbreak_sample.py", "role": "in-the-wild sample"},
    {"script": "experiments/scripts/fetch_advbench_subset.py", "role": "optional AdvBench CSV subset"},
    {"script": "experiments/scripts/fetch_all_paper_datasets.sh", "role": "orchestrate all fetches"}
  ],
  "defense_baselines": [
    {"id": "unified", "paper_ref": "§5.4 unified architecture"},
    {"id": "no_obfuscate", "paper_ref": "§5.4 ablation"},
    {"id": "no_decoy", "paper_ref": "§5.4 ablation"},
    {"id": "intent_only", "paper_ref": "§5.4 baseline (5) proxy"},
    {"id": "direct_upstream", "paper_ref": "§5.4 no gateway"},
    {"id": "smooth_llm", "paper_ref": "§5.4 baseline (4) simplified client jitter"},
    {"id": "structured_wrap", "paper_ref": "§5.4 StruQ-inspired delimiter (see DEFENSE_INVENTORY)"},
    {"id": "strong_system_guard", "paper_ref": "§5.4 baseline (2) partial"},
    {"id": "rag_semantic_only", "paper_ref": "§5.4 baseline (3) client exemplar block"}
  ],
  "scenarios": [
    {"id": "refusal_keyword", "minimal_bundle_axis": null},
    {"id": "extraction_leak", "minimal_bundle_axis": "economics / extraction"},
    {"id": "benign_baseline", "minimal_bundle_axis": "utility"},
    {"id": "multi_round_extraction", "minimal_bundle_axis": "(i) information economics"},
    {"id": "harmful_rsr_suite", "paper_ref": "§5.3 attack (7)", "minimal_bundle_axis": "RSR / SOTA-comparable harmful set"},
    {"id": "wild_rsr_suite", "paper_ref": "§5.3 attack (8) in-the-wild", "minimal_bundle_axis": "real-world prompt drift"},
    {"id": "strongreject_rsr_suite", "paper_ref": "StrongREJECT benchmark (§5.6 empty jailbreak)", "minimal_bundle_axis": "ASR/RSR with evaluator rubric"},
    {"id": "hpm_proxy", "minimal_bundle_axis": "(ii) value / HPM pressure proxy"},
    {"id": "benign_fpr_suite", "minimal_bundle_axis": "FPR / utility"},
    {"id": "decoy_dos_sla", "minimal_bundle_axis": "decoy DoS / SLA"}
  ],
  "out_of_scope_in_artifact": [
    "Track B: white-box GCG / AutoDAN runs (gradient access; separate lab harness)",
    "Full PAIR attack loop (low-query generator; use PAIR-produced prompts as files if needed)",
    "Joint-key retrieval with activation vectors",
    "n>=5 distribution-based judge consensus with Clopper-Pearson gating"
  ],
  "sota_comparison_note": "Primary tables: JBB-Behaviors misuse+benign for joint RSR and benign FPR; optional wild_rsr_suite and strongreject_rsr_suite; compare with AdvBench/GCG literature using same model ID and budgets.",
  "external_sota_guard_baseline": {
    "paper_ref": "BeyondModelReflection §5.4 baseline (6)",
    "role": "Commodity frozen classifier (e.g. Llama Guard) vs gateway stack; not an X-Gateway-Experiment-Mode row",
    "instantiation": "HTTP judge_service with JUDGE_BACKEND=chat_completion and JUDGE_CHAT_MODEL pointing at a served Llama-Guard (or equivalent); or gateway output guard with same backend; record model revision in manifest",
    "openrouter_llama_guard_4": "scripts/run_openrouter_llama_guard4_judge.sh; JUDGE_LLAMA_GUARD_NATIVE=1; relabel stored completions via scripts/relabel_tracka_llama_guard.py after run_paper_benchmark.py --store-assistant-text"
  }
}
